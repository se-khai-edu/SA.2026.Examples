<Window xmlns:Lib="clr-namespace:Ping.WPF.Lib;assembly=Ping.WPF.Lib" 
        x:Class="Demo.WPF.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo.WPF.App"
        d:DataContext="{d:DesignInstance Type=Lib:HostItemViewModel}"
        mc:Ignorable="d" 
        Title="MainWindow" Height="271" Width="550">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="236" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Lib:PingControl 
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
            Margin="5,5,1,1" 
            HostNames="{Binding Hosts}" 
            Grid.Column="0"
            PingChangeState="OnPingChangeState"/>
        <ListBox 
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
            Grid.Column="1"
            x:Name="lbLog" 
            Margin="5" 
            d:ItemsSource="{d:SampleData ItemCount=5}" />
    </Grid>
</Window>
