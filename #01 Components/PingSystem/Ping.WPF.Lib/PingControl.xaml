<UserControl x:Name="ParentControl" x:Class="Ping.WPF.Lib.PingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:Ping.Core;assembly=Ping.Core"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ping.WPF.Lib" 
             d:DataContext="{d:DesignInstance Type=local:HostItemViewModel}"
             mc:Ignorable="d" d:DesignHeight="150" d:DesignWidth="225">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <ListView 
            x:Name="lvHosts" 
            Grid.Row="0" Margin="0" 
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
            ItemsSource="{Binding HostViewModels, ElementName=ParentControl}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="" Width="30">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="16" Height="16">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static core:HostStatus.Null}">
                                                    <Setter Property="Source" Value="/Ping.WPF.Lib;component/Images/DarkGray 16x16.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static core:HostStatus.Online}">
                                                    <Setter Property="Source" Value="/Ping.WPF.Lib;component/Images/Green 16x16.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static core:HostStatus.Offline}">
                                                    <Setter Property="Source" Value="/Ping.WPF.Lib;component/Images/Yellow 16x16.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static core:HostStatus.Unknown}">
                                                    <Setter Property="Source" Value="/Ping.WPF.Lib;component/Images/Gray 16x16.png"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static core:HostStatus.Error}">
                                                    <Setter Property="Source" Value="/Ping.WPF.Lib;component/Images/Red 16x16.png"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn 
                        Header="Host" 
                        DisplayMemberBinding="{Binding Address}" 
                        Width="150" />
                    <GridViewColumn 
                        Header="ms" 
                        DisplayMemberBinding="{Binding RoundtripTime}" 
                        Width="40" />
                </GridView>
            </ListView.View>
        </ListView>

        <CheckBox 
            x:Name="cbRun" 
            Grid.Row="1"
            VerticalAlignment="Bottom" 
            Content="Ping hosts" 
            Margin="5" />
    </Grid>
</UserControl>
